{
  "extends": ["@tsconfig/node22", "@tsconfig/strictest"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "noPropertyAccessFromIndexSignature": false,
    "types": ["node"],
    "module": "preserve",
    "moduleResolution": "bundler"
  }
}
